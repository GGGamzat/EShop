@model Product

@{
    ViewData["Title"] = "Редактирование продукта";
}

<h1>Редактирование продукта питания 🍎</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="EditProduct" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Название продукта *</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Category" class="form-label">Категория *</label>
                        <select asp-for="Category" class="form-select">
                            <option value="">Выберите...</option>
                            <option>Овощи</option>
                            <option>Фрукты</option>
                            <option>Мясо</option>
                            <option>Рыба</option>
                            <option>Молочные продукты</option>
                            <option>Хлебобулочные</option>
                            <option>Бакалея</option>
                            <option>Зелень</option>
                            <option>Напитки</option>
                            <option>Сладости</option>
                            <option>Замороженные продукты</option>
                            <option>Готовая еда</option>
                        </select>
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Description" class="form-label">Описание *</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label">Цена * (₽)</label>
                        <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Unit" class="form-label">Единица измерения</label>
                        <select asp-for="Unit" class="form-select">
                            <option value="кг">кг</option>
                            <option value="г">г</option>
                            <option value="л">л</option>
                            <option value="шт">шт</option>
                            <option value="100г">100г</option>
                            <option value="уп">упаковка</option>
                        </select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Stock" class="form-label">Количество *</label>
                        <input asp-for="Stock" class="form-control" type="number" min="0" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Calories" class="form-label">Калории (ккал/100г)</label>
                        <input asp-for="Calories" class="form-control" type="number" min="0" placeholder="Например: 52" />
                        <small class="text-muted">Оставьте пустым, если неизвестно</small>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Manufacturer" class="form-label">Производитель / Поставщик</label>
                        <input asp-for="Manufacturer" class="form-control" placeholder="Например: Фермерское хозяйство" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ExpiryDate" class="form-label">Срок годности</label>
                        <input asp-for="ExpiryDate" class="form-control" type="date" />
                        <small class="text-muted">Укажите дату, до которой продукт годен</small>
                    </div>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="StorageConditions" class="form-label">Условия хранения</label>
                        <input asp-for="StorageConditions" class="form-control" placeholder="Например: Хранить в холодильнике при +2-4°C" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3 form-check mt-4">
                        <input asp-for="IsOrganic" class="form-check-input" type="checkbox" />
                        <label asp-for="IsOrganic" class="form-check-label">Органический продукт (Organic)</label>
                        <br />
                        <small class="text-muted">Отметьте, если продукт выращен без химикатов</small>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="ImageUrl" class="form-label">URL изображения</label>
                <input asp-for="ImageUrl" class="form-control" placeholder="/images/product.jpg" />
                <small class="text-muted">Добавьте ссылку на фото продукта</small>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Текущее изображение:</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mt-2">
                        <img src="@Model.ImageUrl" alt="@Model.Name" style="max-height: 100px;" onerror="this.onerror=null; this.src='https://via.placeholder.com/100';" />
                        <br />
                        <small class="text-muted">Текущий URL: @Model.ImageUrl</small>
                    </div>
                }
                else
                {
                    <p class="text-muted">Изображение не загружено</p>
                }
            </div>
            
            <hr />
            
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                <strong>Информация о продукте:</strong>
                <ul class="mb-0 mt-2">
                    <li>Создан: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</li>
                    @if (Model.ExpiryDate.HasValue)
                    {
                        <li>Срок годности истекает: @Model.ExpiryDate.Value.ToString("dd.MM.yyyy")</li>
                        if (Model.ExpiryDate.Value < DateTime.Now)
                        {
                            <li class="text-danger">⚠️ ПРОДУКТ ПРОСРОЧЕН!</li>
                        }
                        else if (Model.ExpiryDate.Value < DateTime.Now.AddDays(3))
                        {
                            <li class="text-warning">⚠️ СКОРО ИСТЕКАЕТ СРОК ГОДНОСТИ!</li>
                        }
                    }
                </ul>
            </div>
            
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Сохранить изменения
            </button>
            <a asp-action="Products" class="btn btn-secondary">
                <i class="fas fa-times"></i> Отмена
            </a>
        </form>
    </div>
    
    <div class="col-md-4">
        <div class="card bg-light mb-3">
            <div class="card-body">
                <h6 class="card-title">📝 Советы по заполнению:</h6>
                <ul class="small text-muted">
                    <li>Указывайте точную цену за единицу измерения</li>
                    <li>Для свежих продуктов обязательно указывайте срок годности</li>
                    <li>Категория поможет покупателям находить продукты</li>
                    <li>Органические продукты отмечайте галочкой - это повышает доверие</li>
                    <li>Добавляйте качественные фотографии продуктов</li>
                </ul>
            </div>
        </div>
        
        <div class="card bg-warning bg-opacity-10">
            <div class="card-body">
                <h6 class="card-title">⚠️ Внимание:</h6>
                <ul class="small">
                    <li>При изменении цены, старые заказы не обновляются</li>
                    <li>Уменьшение количества может отменить неоплаченные заказы</li>
                    <li>Просроченные продукты автоматически отмечаются на сайте</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}