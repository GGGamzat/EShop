@model List<Order>

@{
    ViewData["Title"] = "Панель администратора";
    ViewBag.TotalProducts = ViewBag.TotalProducts ?? 0;
    ViewBag.TotalOrders = ViewBag.TotalOrders ?? 0;
    ViewBag.TotalUsers = ViewBag.TotalUsers ?? 0;
    ViewBag.PendingOrders = ViewBag.PendingOrders ?? 0;
}

<h1>Панель администратора</h1>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Товары</h5>
                <h2>@ViewBag.TotalProducts</h2>
                <a asp-action="Products" class="text-white">Управление →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Заказы</h5>
                <h2>@ViewBag.TotalOrders</h2>
                <a asp-action="Orders" class="text-white">Просмотр →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Пользователи</h5>
                <h2>@ViewBag.TotalUsers</h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">В обработке</h5>
                <h2>@ViewBag.PendingOrders</h2>
                <a asp-action="Orders" class="text-white">Обработать →</a>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5>Последние заказы</h5>
    </div>
    <div class="card-body">
        <table class="table">
            <thead>
                <tr><th>№</th><th>Покупатель</th><th>Сумма</th><th>Статус</th><th>Дата</th></tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.User?.Email</td>
                        <td>@order.TotalAmount.ToString("C")</td>
                        <td>@order.Status</td>
                        <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>