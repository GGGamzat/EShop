@model List<Order>

@{
    ViewData["Title"] = "Управление заказами";
}

<h1>Управление заказами</h1>

<table class="table table-hover">
    <thead class="table-dark">
        <tr>
            <th>№</th>
            <th>Покупатель</th>
            <th>Сумма</th>
            <th>Статус</th>
            <th>Дата</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>#@order.Id</td>
                <td>@order.User?.Email</td>
                <td>@order.TotalAmount.ToString("C")</td>
                <td>
                    @{
                        string badgeClass = order.Status == "Pending" ? "bg-warning" : 
                                           (order.Status == "Shipped" ? "bg-info" : 
                                           (order.Status == "Delivered" ? "bg-success" : "bg-danger"));
                    }
                    <span class="badge @badgeClass">@order.Status</span>
                </td>
                <td>@order.OrderDate.ToString("dd.MM.yyyy")</td>
                <td>
                    <form asp-action="UpdateOrderStatus" method="post" class="d-inline">
                        <input type="hidden" name="orderId" value="@order.Id" />
                        <select name="status" class="form-select form-select-sm d-inline" style="width: auto;">
                            @if (order.Status == "Pending")
                            {
                                <option value="Pending" selected>Ожидает</option>
                            }
                            else
                            {
                                <option value="Pending">Ожидает</option>
                            }
                            
                            @if (order.Status == "Shipped")
                            {
                                <option value="Shipped" selected>Отправлен</option>
                            }
                            else
                            {
                                <option value="Shipped">Отправлен</option>
                            }
                            
                            @if (order.Status == "Delivered")
                            {
                                <option value="Delivered" selected>Доставлен</option>
                            }
                            else
                            {
                                <option value="Delivered">Доставлен</option>
                            }
                            
                            @if (order.Status == "Cancelled")
                            {
                                <option value="Cancelled" selected>Отменен</option>
                            }
                            else
                            {
                                <option value="Cancelled">Отменен</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary">Обновить</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>