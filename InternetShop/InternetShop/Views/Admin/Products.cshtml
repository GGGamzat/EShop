@model List<Product>

@{
    ViewData["Title"] = "Управление товарами";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Управление товарами</h1>
    <a asp-action="CreateProduct" class="btn btn-success">+ Добавить товар</a>
</div>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Цена</th>
            <th>Количество</th>
            <th>Категория</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var product in Model)
        {
            <tr>
                <td>@product.Id</td>
                <td>@product.Name</td>
                <td>@product.Price.ToString("C")</td>
                <td>@product.Stock</td>
                <td>@product.Category</td>
                <td>
                    <a asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-warning">✏️</a>
                    <form asp-action="DeleteProduct" method="post" style="display:inline">
                        <input type="hidden" name="id" value="@product.Id" />
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить товар?')">🗑️</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>