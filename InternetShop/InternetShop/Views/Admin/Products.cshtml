@model List<Product>

@{
    ViewData["Title"] = "Управление продуктами";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Управление продуктами питания 🍎</h1>
    <a asp-action="CreateProduct" class="btn btn-success">+ Добавить продукт</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Категория</th>
            <th>Цена</th>
            <th>Ед.</th>
            <th>Кол-во</th>
            <th>Срок годности</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>@(product.Category ?? "-")</td>
                    <td>@product.Price.ToString("C")</td>
                    <td>@(product.Unit ?? "шт")</td>
                    <td>@product.Stock</td>
                    <td>
                        @if (product.ExpiryDate.HasValue)
                        {
                            @if (product.ExpiryDate.Value < DateTime.Now)
                            {
                                <span class="badge bg-danger">Просрочен</span>
                            }
                            else if (product.ExpiryDate.Value < DateTime.Now.AddDays(3))
                            {
                                <span class="badge bg-warning">Скоро портится</span>
                            }
                            else
                            {
                                <span>@product.ExpiryDate.Value.ToString("dd.MM.yyyy")</span>
                            }
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                    <td>
                        <a asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-warning">✏️</a>
                        <form asp-action="DeleteProduct" method="post" style="display:inline">
                            <input type="hidden" name="id" value="@product.Id" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Удалить продукт?')">🗑️</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="8" class="text-center">Нет продуктов</td>
            </tr>
        }
    </tbody>
</table>