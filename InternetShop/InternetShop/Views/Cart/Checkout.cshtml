@model InternetShop.Models.Order

@{
    ViewData["Title"] = "Оформление заказа";
    var cart = ViewContext.HttpContext.Session.GetString("ShoppingCart");
    var cartItems = !string.IsNullOrEmpty(cart) 
        ? System.Text.Json.JsonSerializer.Deserialize<List<InternetShop.Models.CartItem>>(cart) 
        : new List<InternetShop.Models.CartItem>();
}

<h1>Оформление заказа</h1>

<div class="row">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <h5>Контактная информация</h5>
            </div>
            <div class="card-body">
                <form asp-action="Checkout" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="ShippingAddress" class="form-label">Адрес доставки *</label>
                        <input asp-for="ShippingAddress" class="form-control" required />
                        <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label">Телефон *</label>
                        <input asp-for="PhoneNumber" class="form-control" required />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check"></i> Подтвердить заказ
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Назад к корзине</a>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-5">
        <div class="card">
            <div class="card-header">
                <h5>Ваш заказ</h5>
            </div>
            <div class="card-body">
                @if (cartItems != null && cartItems.Any())
                {
                    @foreach (var item in cartItems)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            <span>@item.ProductName x @item