@model Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="row">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body text-center">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="max-height: 300px;" onerror="this.onerror=null; this.src='https://via.placeholder.com/300';" />
                }
                else
                {
                    <i class="fas fa-apple-alt fa-5x text-success"></i>
                }
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card">
            <div class="card-body">
                <h1>@Model.Name</h1>
                <div class="mb-2">
                    <span class="badge bg-info">@Model.Category</span>
                    @if (Model.IsOrganic)
                    {
                        <span class="badge bg-success">Органический</span>
                    }
                    @if (Model.ExpiryDate.HasValue && Model.ExpiryDate.Value < DateTime.Now.AddDays(3))
                    {
                        <span class="badge bg-warning">Скоро портится</span>
                    }
                </div>
                
                <p class="lead">@Model.Description</p>
                
                <table class="table table-bordered">
                    <tr>
                        <th>Цена:</th>
                        <td><span class="h2 text-primary">@Model.Price.ToString("C")</span> / @Model.Unit</td>
                    </tr>
                    <tr>
                        <th>Наличие:</th>
                        <td>
                            @if (Model.Stock > 0)
                            {
                                <span class="text-success">В наличии (@Model.Stock @Model.Unit)</span>
                            }
                            else
                            {
                                <span class="text-danger">Нет в наличии</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Калорийность:</th>
                        <td>@(Model.Calories.HasValue ? $"{Model.Calories} ккал/100г" : "Не указано")</td>
                    </tr>
                    <tr>
                        <th>Производитель:</th>
                        <td>@(string.IsNullOrEmpty(Model.Manufacturer) ? "Не указан" : Model.Manufacturer)</td>
                    </tr>
                    <tr>
                        <th>Срок годности:</th>
                        <td>
                            @if (Model.ExpiryDate.HasValue)
                            {
                                @if (Model.ExpiryDate.Value < DateTime.Now)
                                {
                                    <span class="text-danger">Просрочен</span>
                                }
                                else
                                {
                                    <span>@Model.ExpiryDate.Value.ToString("dd.MM.yyyy")</span>
                                }
                            }
                            else
                            {
                                <span>Не указан</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Условия хранения:</th>
                        <td>@(string.IsNullOrEmpty(Model.StorageConditions) ? "Стандартные" : Model.StorageConditions)</td>
                    </tr>
                </table>
                
                @if (Model.Stock > 0)
                {
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="row g-3 align-items-center">
                            <div class="col-auto">
                                <label class="col-form-label">Количество:</label>
                            </div>
                            <div class="col-auto">
                                <input type="number" name="quantity" value="1" min="1" max="@Model.Stock" class="form-control" style="width: 100px;" />
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-cart-plus"></i> Добавить в корзину
                                </button>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary btn-lg" disabled>Нет в наличии</button>
                }
            </div>
        </div>
    </div>
</div>

@if (ViewBag.SimilarProducts != null && ((List<Product>)ViewBag.SimilarProducts).Any())
{
    <hr />
    <h3 class="mt-4">Похожие продукты</h3>
    <div class="row">
        @foreach (var product in (List<Product>)ViewBag.SimilarProducts)
        {
            <div class="col-md-3">
                <div class="card product-card">
                    <div class="card-body">
                        <h6>@product.Name</h6>
                        <p class="text-primary">@product.Price.ToString("C")</p>
                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-outline-primary">Подробнее</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<a asp-action="Index" class="btn btn-secondary mt-3">← Назад к покупкам</a>