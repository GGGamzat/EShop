@model List<Order>

@{
    ViewData["Title"] = "Мои заказы";
}

<h1>Мои заказы</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">
        У вас пока нет заказов. <a asp-controller="Home" asp-action="Index">Перейти к покупкам</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>№ заказа</th>
                    <th>Дата</th>
                    <th>Сумма</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@order.TotalAmount.ToString("C")</td>
                        <td>
                            @if (order.Status == "Pending")
                            {
                                <span class="badge bg-warning">Ожидает</span>
                            }
                            else if (order.Status == "Shipped")
                            {
                                <span class="badge bg-info">Отправлен</span>
                            }
                            else if (order.Status == "Delivered")
                            {
                                <span class="badge bg-success">Доставлен</span>
                            }
                            else if (order.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">Отменен</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-primary">Детали</a>
                            @if (order.Status == "Pending")
                            {
                                <form asp-action="CancelOrder" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@order.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Отменить заказ?')">Отменить</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}